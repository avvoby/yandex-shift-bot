# Токен Telegram-бота от BotFather
BOT_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE

# ID Google-таблицы
GOOGLE_SHEETS_ID=PASTE_YOUR_GOOGLE_SHEETS_ID_HERE

# JSON-файл service account
GOOGLE_CREDENTIALS_FILE=credentials.json

# Часовой пояс
TIMEZONE=Europe/Berlin

# Кэш по умолчанию
DEFAULT_CACHE_MINUTES=10

# Размер пачки рассылки
DEFAULT_BROADCAST_CHUNK_SIZE=20

# Логи
LOG_LEVEL=INFO
